.DS_Store
.env
.env.*
node_modules/
*.log
.tmp/

# Internal launch / marketing drafts — local only, never pushed.
.launch/

# Local working scratchpads — bug intake + review notes. Kept private: resolved
# items graduate to CHANGELOG.md (the fix), SCARS.md (the lesson), and SPEC.md
# (the rule); these drafts also reference internal repos/paths. Local only.
BUGS.md
CRITICS.md

# The autonomous-loop surface for THIS repo — local only, never pushed.
# The roadmap is forward-looking strategy: features go public one release at a
# time, only after full verification (the SPEC/CHANGELOG in the release IS the
# public trace); the loop files also reference private local paths. Repos that
# WANT a public loop simply don't ignore these — per-repo choice, not the standard.
LOOP.md
ROADMAP.md
LOOP_REPORT.md
LOOP_HISTORY.md

# Local agent-session settings.
.claude/

# Private-style overlays — if you maintain a private style preset as
# a sibling repo and symlink it into templates/styles/ via an overlay
# install.sh, these patterns keep the symlink out of git.
#
# `abbasi` is maintained privately (GitLab-only) and dropped in via the
# Atlas-private overlay's install.sh, which symlinks it into this dir at
# install time. It must NEVER be committed here: the symlink target is an
# absolute local path, so committing it leaks that path AND ships a dangling
# link to every npm/brew/.deb/AUR consumer.
templates/styles/abbasi
templates/styles/*-private
templates/styles/*-internal

# Local atlas-mirror config when someone tests inside this repo.
.atlas/
